---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <!-- JSON-LD Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": frontmatter.title,
    "image": frontmatter.image,
    "author": {
      "@type": "Organization",
      "name": "SRLaundry"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SRLaundry",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.srlaundry.site/favicon.png"
      }
    },
    "datePublished": frontmatter.date
  })} />

  <article class="pt-32 pb-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="mb-10 text-center reveal">
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-950 mb-6 leading-tight">{frontmatter.title}</h1>
        <p class="text-gray-500 mb-6">Diterbitkan pada {frontmatter.date}</p>
        {frontmatter.image && (
          <img src={frontmatter.image} alt={frontmatter.title} class="w-full h-[400px] object-cover rounded-3xl shadow-lg" />
        )}
      </div>
      <div class="artikel-content max-w-none reveal">
        <slot />
      </div>
      <div class="mt-16 text-center reveal">
        <a href="/" class="text-red-600 font-bold hover:underline">← Kembali ke Beranda</a>
      </div>
    </div>
  </article>

  <style is:global>
    @reference "../styles/global.css";
    
    .artikel-content h2 {
      @apply text-3xl font-bold mt-10 mb-4 text-gray-900;
    }
    .artikel-content h3 {
      @apply text-2xl font-bold mt-8 mb-3 text-gray-900;
    }
    .artikel-content p {
      @apply text-lg text-gray-700 leading-relaxed mb-6;
    }
    .artikel-content ul {
      @apply list-disc pl-6 mb-6 text-lg text-gray-700 space-y-2;
    }
    .artikel-content ol {
      @apply list-decimal pl-6 mb-6 text-lg text-gray-700 space-y-2;
    }
    .artikel-content strong {
      @apply font-bold text-gray-900;
    }
  </style>
</BaseLayout>
