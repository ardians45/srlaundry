---
import { Image } from 'astro:assets';
import logo from '../assets/logo-removebg.png';

const currentYear = new Date().getFullYear();

const footerLinks = {
  MENU: [
    { name: 'About', href: '/tentang' },
    { name: 'Layanan', href: '/layanan' },
    { name: 'Promo', href: '/promo' },
    { name: 'Testimoni', href: '/testimoni' },
  ],
  SERVICES: [
    { name: 'Cuci Kering', href: '/layanan' },
    { name: 'Cuci Setrika', href: '/layanan' },
    { name: 'Setrika Saja', href: '/layanan' },
    { name: 'Kilat 2 Jam', href: '/layanan' },
  ],
  LEGAL: [
    { name: 'Terms', href: '#' },
    { name: 'Privacy', href: '#' },
    { name: 'Cookies', href: '#' },
  ]
};
---

<footer class="bg-brand-gradient text-white pt-24 pb-12 overflow-hidden border-t border-white/10">
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-20">
      
      <!-- Brand Section -->
      <div class="space-y-8">
        <a href="/" class="inline-block group">
           <Image src={logo} alt="SR Laundry Logo" class="h-24 w-auto drop-shadow-xl transition-transform group-hover:scale-105" />
        </a>
        <p class="text-lg font-medium leading-relaxed opacity-90 max-w-sm">
          Solusi laundry modern terpercaya di Ciledug. Kami hadir untuk membuat hidup Anda lebih praktis dengan layanan berkualitas tinggi.
        </p>
        <div class="flex gap-4">
          <a href="https://wa.me/6281297252322" target="_blank" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white hover:text-primary transition-all duration-300">
            <i class="fab fa-whatsapp"></i>
          </a>
          <a href="https://www.instagram.com/srlaundrycoin/" target="_blank" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white hover:text-primary transition-all duration-300">
            <i class="fab fa-instagram"></i>
          </a>
        </div>
      </div>

      <!-- Links Sections -->
      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/50 mb-8">Eksplorasi</p>
        <ul class="space-y-4">
          {footerLinks.MENU.map(link => (
            <li>
              <a href={link.href} class="text-sm font-bold uppercase tracking-widest hover:pl-2 transition-all duration-300">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/50 mb-8">Layanan</p>
        <ul class="space-y-4">
          {footerLinks.SERVICES.map(link => (
            <li>
              <a href={link.href} class="text-sm font-bold uppercase tracking-widest hover:pl-2 transition-all duration-300">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Section -->
      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/50 mb-8">Lokasi & Jam</p>
        <div class="space-y-6">
          <div class="flex gap-3">
             <i class="fas fa-map-marker-alt opacity-50 mt-1"></i>
             <p class="text-sm font-bold uppercase tracking-widest leading-loose">
               LARANGAN SELATAN, CILEDUG,<br/>
               KOTA TANGERANG, BANTEN.
             </p>
          </div>
          <div class="flex gap-3">
             <i class="fas fa-clock opacity-50 mt-1"></i>
             <p class="text-sm font-bold uppercase tracking-widest">
               EVERYDAY 07:00 – 21:00
             </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-12 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-8 text-center md:text-left">
       <div class="flex flex-col gap-2">
          <div class="flex justify-center md:justify-start gap-6">
            {footerLinks.LEGAL.map(link => (
              <a href={link.href} class="text-[10px] font-black uppercase tracking-widest text-white/50 hover:text-white transition-colors">
                {link.name}
              </a>
            ))}
          </div>
          <p class="text-[10px] font-black uppercase tracking-widest opacity-30 mt-2">
            &copy; {currentYear} SR LAUNDRY EXPRESS. ALL RIGHTS RESERVED.
          </p>
       </div>
       
       <div class="hidden lg:block">
          <h2 class="font-editorial text-4xl font-black uppercase tracking-tighter opacity-10 select-none">
            SR LAUNDRY.
          </h2>
       </div>
    </div>
  </div>

  <!-- Large Background Text (Mobile Friendly) -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden pointer-events-none select-none opacity-5 translate-y-1/2">
     <h2 class="font-editorial text-[25vw] font-black uppercase tracking-tighter whitespace-nowrap leading-none">
       SR LAUNDRY SR LAUNDRY SR LAUNDRY
     </h2>
  </div>
</footer>
