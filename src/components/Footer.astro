---
import { Image } from 'astro:assets';
import logo from '../assets/logo-removebg.png';

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-300 pt-20 pb-10">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-6">
          <Image src={logo} alt="SR Laundry Logo" class="h-16 w-auto" />
        </a>
        <p class="text-lg text-gray-400 max-w-md leading-relaxed">
          SR Laundry adalah solusi laundry modern terpercaya di Ciledug, berkomitmen pada kebersihan, kecepatan, dan kepuasan Anda. Kami hadir untuk membuat hidup Anda lebih praktis.
        </p>
        <div class="flex gap-4 mt-8">
          <a href="https://wa.me/6281297252322" target="_blank" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-900 border border-gray-800 hover:bg-red-700 hover:border-red-700 hover:text-white transition-all">
            <i class="fab fa-whatsapp"></i>
          </a>
          <a href="https://www.instagram.com/srlaundrycoin/" target="_blank" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-900 border border-gray-800 hover:bg-red-700 hover:border-red-700 hover:text-white transition-all">
            <i class="fab fa-instagram"></i>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-bold text-xl mb-6">Navigasi</h3>
        <ul class="space-y-4">
          <li><a href="/tentang" class="hover:text-red-500 transition-colors">Tentang Kami</a></li>
          <li><a href="/layanan" class="hover:text-red-500 transition-colors">Layanan & Harga</a></li>
          <li><a href="/promo" class="hover:text-red-500 transition-colors">Promo Spesial</a></li>
          <li><a href="/testimoni" class="hover:text-red-500 transition-colors">Testimoni</a></li>
          <li><a href="/kontak" class="hover:text-red-500 transition-colors">Kontak</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold text-xl mb-6">Informasi</h3>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <i class="fas fa-map-marker-alt text-red-600 mt-1"></i>
            <span>Cabang Larangan: Larangan Selatan, Ciledug, Kota Tangerang</span>
          </li>
          <li class="flex gap-3">
            <i class="fas fa-clock text-red-600 mt-1"></i>
            <span>Buka Setiap Hari<br/>07:00 – 21:00 WIB</span>
          </li>
          <li class="flex gap-3">
            <i class="fas fa-envelope text-red-600 mt-1"></i>
            <a href="mailto:info@srlaundry.co.id" class="hover:text-white">info@srlaundry.co.id</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-gray-900 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>&copy; {currentYear} SR Laundry Express. All Rights Reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-gray-300">Privacy Policy</a>
        <a href="#" class="hover:text-gray-300">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
