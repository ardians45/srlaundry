---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const navItems = [
  { name: 'Home', href: '/' },
  { name: 'Tentang', href: '/tentang' },
  { name: 'Layanan & Harga', href: '/layanan' },
  { name: 'Promo', href: '/promo' },
  { name: 'Testimoni', href: '/testimoni' },
  { name: 'Kontak', href: '/kontak' },
];
---

<header id="main-header" class="fixed top-0 w-full z-50 transition-all duration-500 py-6">
  <div class="container mx-auto px-6">
    <nav class="flex justify-between items-center transition-all duration-500">
      <a href="/" class="flex items-center gap-2 group">
        <div class="flex flex-col">
          <span class="font-editorial font-black text-primary leading-none text-2xl uppercase tracking-tighter group-hover:text-primary-light transition-colors">SR LAUNDRY.</span>
          <span class="text-[8px] font-bold text-gray-400 uppercase tracking-[0.3em]">EXPRESS & COIN</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map(item => (
          <a 
            href={item.href} 
            data-astro-prefetch
            class="text-[10px] font-black uppercase tracking-widest text-gray-600 hover:text-primary transition-all duration-200"
          >
            {item.name}
          </a>
        ))}
        <a 
          href="/booking" 
          data-astro-prefetch
          class="bg-primary text-white px-8 py-3 rounded-full font-black text-[10px] uppercase tracking-widest hover:bg-primary-dark transition-all duration-300 shadow-xl"
        >
          BOOK NOW
        </a>
      </div>

      <!-- Mobile Toggle -->
      <button id="mobile-menu-toggle" class="lg:hidden p-2 text-gray-700" aria-label="Toggle Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-white z-[60] flex flex-col p-8 transition-all duration-500 translate-x-full lg:hidden">
    <div class="flex justify-between items-center mb-12">
      <div class="flex items-center gap-2">
        <Image src={logo} alt="Logo" class="h-10 w-10 rounded-full" />
        <span class="font-black text-red-700 text-xl tracking-tighter">SR LAUNDRY</span>
      </div>
      <button id="mobile-menu-close" class="p-2 text-gray-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <div class="flex flex-col gap-6">
      {navItems.map(item => (
        <a href={item.href} data-astro-prefetch class="text-2xl font-bold text-gray-800 hover:text-red-700 transition-colors">
          {item.name}
        </a>
      ))}
      <a 
        href="/booking" 
        data-astro-prefetch
        class="mt-4 bg-red-700 text-white text-center py-4 rounded-2xl font-bold text-xl shadow-xl active:scale-95 transition-transform"
      >
        Booking Sekarang
      </a>
    </div>

    <div class="mt-auto flex flex-col gap-4 text-center">
      <p class="text-gray-500 font-medium italic">"Pakaian Bersih, Hidup Praktis"</p>
      <div class="flex justify-center gap-4">
        <a href="#" class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 text-gray-600">
          <i class="fab fa-instagram text-xl"></i>
        </a>
        <a href="#" class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 text-gray-600">
          <i class="fab fa-whatsapp text-xl"></i>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const header = document.getElementById('main-header');
    const menuLinks = menu?.querySelectorAll('a');

    toggle?.addEventListener('click', () => {
      menu?.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden'; // Prevent scroll when menu open
    });

    close?.addEventListener('click', () => {
      menu?.classList.add('translate-x-full');
      document.body.style.overflow = '';
    });

    // Close menu when a link is clicked
    menuLinks?.forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('translate-x-full');
        document.body.style.overflow = '';
      });
    });

    // Header scroll effect
    const handleScroll = () => {
      if (window.scrollY > 20) {
        header?.classList.add('py-4', 'bg-white', 'shadow-md');
        header?.classList.remove('py-6');
      } else {
        header?.classList.add('py-6');
        header?.classList.remove('py-4', 'bg-white', 'shadow-md');
      }
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Initial check
  }

  // Initialize on load and after navigation
  document.addEventListener('astro:page-load', initHeader);
</script>
