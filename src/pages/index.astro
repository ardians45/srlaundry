---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroAi from '../assets/hero-ai.png';
import mesinJpg from '../assets/mesin.jpg';
import maintenanceJpg from '../assets/maintenance.jpg';
import galeri1 from '../assets/galeri1.jpg';
import galeri2 from '../assets/galeri2.jpg';
import galeri3 from '../assets/galeri3.jpg';
import galeri4 from '../assets/galeri4.jpg';

const services = [
  { id: '01', name: 'Cuci Kering', count: '1250+' },
  { id: '02', name: 'Cuci Setrika', count: '850+' },
  { id: '03', name: 'Setrika Saja', count: '420+' },
  { id: '04', name: 'Layanan Kilat', count: '2 hour' },
];

const stats = [
  { label: 'PELANGGAN PUAS', value: '10K+' },
  { label: 'PAKAIAN BERSIH', value: '50K+' },
  { label: 'CABANG', value: '3' },
];
---

<BaseLayout title="Laundry Coin Ciledug Terpercaya & Higienis | SR Laundry Express">
  
  <div class="editorial-grid min-h-screen overflow-hidden">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-12 md:pt-32 px-6">
      <div class="container mx-auto">
        <div class="flex flex-col md:flex-row items-center justify-between gap-12 relative z-10">
          
          <!-- Image Section (Order 1 on Mobile) -->
          <div class="w-full md:w-1/3 order-1 md:order-2 flex justify-center relative mb-8 md:mb-0">
            <div class="absolute -top-10 -right-10 text-primary animate-spin-slow opacity-20 hidden md:block">
              <i class="fas fa-certificate text-6xl"></i>
            </div>
            <div class="relative group">
              <div class="absolute -inset-4 bg-primary/5 rounded-editorial rotate-3 transition-transform group-hover:rotate-6"></div>
              <Image 
                src={heroAi} 
                alt="SR Laundry Hero" 
                class="w-full max-w-[320px] md:max-w-[400px] h-auto object-cover rounded-editorial shadow-2xl relative z-10"
              />
              <div class="absolute -bottom-6 -right-6 md:-bottom-12 md:-left-12 bg-white w-24 h-24 md:w-32 md:h-32 flex flex-col items-center justify-center rounded-3xl shadow-xl z-20 reveal">
                <div class="w-10 h-10 md:w-12 md:h-12 bg-primary text-white flex items-center justify-center rounded-xl mb-2">
                  <i class="fas fa-arrow-right -rotate-45"></i>
                </div>
                <p class="text-[8px] md:text-[10px] font-black uppercase tracking-widest">CEK LAYANAN</p>
              </div>
            </div>
          </div>

          <!-- Left Info Section (Order 2 on Mobile) -->
          <div class="w-full md:w-1/3 order-2 md:order-1 flex flex-col items-center md:items-start text-center md:text-left">
            <h1 class="font-editorial text-4xl sm:text-6xl md:text-[6.5vw] leading-[0.9] font-black uppercase tracking-tighter reveal">
              Layanan Laundry <br class="hidden md:block" /><span class="text-primary">Coin Ciledug.</span>
            </h1>
            <div class="mt-8 flex flex-col md:flex-row items-center gap-4 reveal">
              <div class="flex -space-x-3">
                <img src="https://i.pravatar.cc/100?u=1" class="w-10 h-10 rounded-full border-2 border-white" alt="User" />
                <img src="https://i.pravatar.cc/100?u=2" class="w-10 h-10 rounded-full border-2 border-white" alt="User" />
                <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold border-2 border-white">+</div>
              </div>
              <p class="text-[10px] font-bold uppercase tracking-widest leading-tight text-gray-500">
                DIPERCAYA OLEH<br/>10,000+ PELANGGAN
              </p>
            </div>
            <p class="mt-10 text-sm md:text-base font-medium text-gray-600 max-w-[280px] leading-relaxed reveal">
              SR Laundry Express menyediakan layanan <strong>laundry coin Ciledug</strong> dengan sistem koin reward unik. Cuci bersih, higienis, dan hemat di Paninggilan, Parung Serab, dan sekitarnya.
            </p>
          </div>

          <!-- Right Info Section (Order 3 on Mobile) -->
          <div class="w-full md:w-1/3 order-3 md:order-3 flex flex-col items-center md:items-end text-center md:text-right">
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400 mb-4 reveal">// PREMIUM LAUNDRY</p>
            <h2 class="font-editorial text-5xl sm:text-7xl md:text-[6vw] leading-[0.9] font-black uppercase tracking-tighter reveal">
              Tanpa <br class="hidden md:block" /><span class="text-primary">Ribet.</span>
            </h2>
            
            <div class="mt-12 md:mt-16 space-y-8 reveal w-full">
              {stats.map(s => (
                <div class="flex flex-col items-center md:items-end">
                  <p class="text-5xl md:text-6xl font-black tracking-tighter">{s.value}</p>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-gray-500">{s.label}</p>
                </div>
              ))}
            </div>
          </div>

        </div>

        <div class="mt-20 flex flex-col md:flex-row items-center md:items-end justify-between gap-8 border-t border-gray-100 pt-8 reveal">
          <div class="flex gap-2">
             <i class="fas fa-star text-primary text-[10px]"></i>
             <i class="fas fa-star text-primary text-[10px]"></i>
             <i class="fas fa-star text-primary text-[10px]"></i>
             <i class="fas fa-star text-primary text-[10px]"></i>
             <i class="fas fa-star text-primary text-[10px]"></i>
          </div>
          <p class="text-xs font-bold uppercase tracking-widest text-gray-400 text-center">
            [SCROLL DOWN]
          </p>
          <div class="max-w-[200px] text-center md:text-right">
            <p class="text-[10px] font-bold text-gray-500 uppercase leading-relaxed">
              Nikmati hidup lebih praktis dengan layanan laundry modern, cepat, dan higienis.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <div class="py-12 bg-primary text-white mt-12 overflow-hidden reveal">
      <div class="marquee">
        <div class="marquee-content">
          {Array(10).fill(0).map(() => (
            <span class="text-lg sm:text-2xl font-black uppercase tracking-tighter flex items-center gap-4">
              SR LAUNDRY EXPRESS <span class="text-primary">•</span> 2 JAM SELESAI <span class="text-primary">•</span> 1 MESIN 1 PELANGGAN <span class="text-primary">•</span>
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- About Section -->
    <section class="py-20 md:py-32 px-6 bg-white relative overflow-hidden">
      <div class="container mx-auto grid md:grid-cols-2 gap-20 items-center">
        <div class="relative reveal">
          <div class="absolute top-0 left-0 text-primary text-6xl opacity-10 font-black">- 01</div>
          <h2 class="font-editorial text-4xl sm:text-7xl font-black uppercase tracking-tighter leading-none mt-4">
            Ini Tentang <br/> <span class="text-primary">Waktu Anda</span>
          </h2>
          <p class="mt-8 text-lg text-gray-600 font-medium leading-relaxed max-w-lg">
            Kami percaya waktu Anda terlalu berharga untuk mencuci. Biarkan kami yang menangani cucian Anda dengan standar hotel bintang lima.
          </p>
          <div class="mt-12">
            <a href="/booking" class="inline-flex items-center gap-4 px-8 py-4 bg-primary text-white rounded-full font-bold transition-all hover:gap-6 group">
              HUBUNGI KAMI <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
        <div class="relative reveal">
           <div class="absolute -inset-10 bg-gray-50 rounded-full blur-3xl -z-10"></div>
           <div class="grid grid-cols-2 gap-4">
              <div class="space-y-4">
                <Image src={mesinJpg} alt="Mesin" class="rounded-3xl shadow-lg aspect-[3/4] object-cover" />
                <div class="bg-primary p-8 rounded-3xl text-white">
                  <p class="text-4xl font-black leading-none">2 Jam</p>
                  <p class="text-[10px] font-bold uppercase tracking-widest mt-2">Cepat & Tuntas</p>
                </div>
              </div>
              <div class="pt-12">
                <Image src={maintenanceJpg} alt="Maintenance" class="rounded-3xl shadow-lg aspect-[3/4] object-cover" />
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- Services List Section -->
    <section class="py-20 md:py-32 px-6">
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 gap-20">
          <div class="reveal">
            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400 mb-8">[ LAYANAN KAMI ]</p>
            <div class="divide-y divide-gray-100">
              {services.map(s => (
                <div class="group py-8 flex items-center justify-between hover:px-4 transition-all duration-500 hover:bg-white hover:shadow-xl rounded-2xl">
                  <div class="flex items-center gap-8">
                    <span class="text-xs font-bold text-gray-300">[{s.id}]</span>
                    <h3 class="text-3xl md:text-5xl font-black uppercase tracking-tighter transition-colors group-hover:text-primary">
                      {s.name} <span class="text-xl md:text-2xl text-gray-300 font-normal">({s.count})</span>
                    </h3>
                  </div>
                  <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                    <i class="fas fa-plus text-primary text-2xl"></i>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-12 reveal">
               <a href="/layanan" class="text-xs font-black uppercase tracking-widest border-b-2 border-primary pb-2 hover:text-primary transition-colors">
                  LIHAT SEMUA LAYANAN
               </a>
            </div>
          </div>
          <div class="relative reveal">
            <div class="sticky top-24">
              <div class="relative">
                <div class="absolute -top-10 -left-10 w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center text-primary text-2xl">
                  <i class="fas fa-shield-alt"></i>
                </div>
                <div class="bg-white p-2 rounded-editorial shadow-2xl overflow-hidden group">
                  <Image src={galeri1} alt="Gallery" class="w-full h-auto rounded-editorial object-cover transition-transform duration-700 group-hover:scale-110" />
                </div>
                <div class="absolute -bottom-10 -right-10 bg-primary text-white p-8 rounded-3xl max-w-[200px]">
                   <p class="text-xs font-bold uppercase tracking-widest opacity-60 mb-2">KEAMANAN</p>
                   <p class="text-sm font-medium leading-relaxed">Satu mesin hanya untuk satu pelanggan. Tanpa campur.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial Editorial -->
    <section class="py-20 md:py-32 px-6 bg-brand-gradient text-white relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 text-primary opacity-20">
        <i class="fas fa-quote-right text-[20vw]"></i>
      </div>
      <div class="container mx-auto relative z-10">
        <div class="grid md:grid-cols-12 gap-12 items-center">
          <div class="md:col-span-4 reveal">
            <div class="relative aspect-square bg-primary flex items-center justify-center rounded-editorial-alt text-white">
               <span class="font-editorial text-7xl sm:text-9xl md:text-[15vw] font-black uppercase">AD</span>
               <div class="absolute top-6 left-6 bg-white text-primary px-4 py-2 rounded-full text-[10px] font-black uppercase tracking-widest shadow-xl">
                 PELANGGAN SETIA
               </div>
            </div>
          </div>
          <div class="md:col-span-8 reveal">
            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-8">[ TESTIMONIAL ]</p>
            <h2 class="text-3xl sm:text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none mb-12">
              "Layanan terbaik di Ciledug! Kualitas laundry-nya setara hotel bintang 5, wangi & rapi."
            </h2>
            <div class="flex items-center justify-between flex-wrap gap-8">
               <div class="flex items-center gap-4">
                  <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center text-2xl">
                    <i class="fas fa-play"></i>
                  </div>
                  <div>
                    <p class="text-xl font-black uppercase tracking-tighter">AKBAR DJ</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest opacity-50">ENTREPRENEUR</p>
                  </div>
               </div>
               <div class="flex gap-12">
                 <div>
                    <p class="text-4xl font-black uppercase tracking-tighter">4.9/5</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest opacity-50">GOOGLE RATING</p>
                 </div>
                 <div>
                    <p class="text-4xl font-black uppercase tracking-tighter">100%</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest opacity-50">KEPUASAN</p>
                 </div>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gallery Editorial Grid -->
    <section class="py-20 md:py-32 px-6">
      <div class="container mx-auto">
        <div class="flex flex-col md:flex-row items-end justify-between mb-16 reveal">
           <div>
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400 mb-4">[ GALERI ]</p>
              <h2 class="font-editorial text-4xl sm:text-7xl font-black uppercase tracking-tighter leading-none">
                Kualitas<br/><span class="text-primary">Terjamin.</span>
              </h2>
           </div>
           <div class="max-w-[300px] mt-8 md:mt-0 text-right">
              <p class="text-sm font-medium text-gray-500 leading-relaxed mb-6">
                Setiap helai pakaian Anda ditangani dengan penuh perhatian oleh tim profesional kami menggunakan mesin modern.
              </p>
              <a href="/testimoni" class="inline-flex items-center gap-4 text-xs font-black uppercase tracking-widest group">
                LIHAT SEMUA <span class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center transition-transform group-hover:translate-x-2"><i class="fas fa-arrow-right"></i></span>
              </a>
           </div>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 reveal">
           <div class="md:col-span-2 md:row-span-2 relative overflow-hidden rounded-editorial-alt group shadow-xl">
             <Image src={galeri3} alt="Gallery" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
           </div>
           <div class="aspect-square relative overflow-hidden rounded-3xl group shadow-lg">
             <Image src={galeri4} alt="Gallery" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
           </div>
           <div class="aspect-square relative overflow-hidden rounded-3xl group shadow-lg md:translate-y-12">
             <Image src={galeri1} alt="Gallery" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
           </div>
           <div class="aspect-square relative overflow-hidden rounded-3xl group shadow-lg">
             <Image src={mesinJpg} alt="Gallery" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
           </div>
           <div class="aspect-square relative overflow-hidden rounded-3xl group shadow-lg md:-translate-y-12">
             <Image src={galeri2} alt="Gallery" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
           </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-20 md:py-32 px-6">
       <div class="container mx-auto">
          <div class="bg-primary rounded-[3rem] p-12 md:p-32 text-center text-white relative overflow-hidden reveal">
             <div class="absolute -top-20 -left-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
             <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-black/10 rounded-full blur-3xl"></div>
             
             <div class="relative z-10">
                <p class="text-xs font-black uppercase tracking-[0.4em] mb-8 opacity-70">SIAP MENCUCI?</p>
                <h2 class="font-editorial text-5xl sm:text-8xl md:text-[8vw] font-black uppercase tracking-tighter leading-[0.8] mb-12">
                   Boking<br/>Sekarang.
                </h2>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                   <a href="/booking" class="w-full sm:w-auto px-8 py-5 bg-white text-primary rounded-full font-black text-base hover:bg-gray-100 transition-all transform hover:-translate-y-1">
                      WHATSAPP KAMI
                   </a>
                   <a href="/kontak" class="w-full sm:w-auto px-8 py-5 bg-transparent border-2 border-white/30 text-white rounded-full font-black text-base hover:bg-white/10 transition-all">
                      KONTAK
                   </a>
                </div>
             </div>
          </div>
       </div>
    </section>
  </div>

  <style>
    .animate-spin-slow {
      animation: spin 10s linear infinite;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>

</BaseLayout>
