---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import mesinJpg from '../assets/mesin.jpg';
import maintenanceJpg from '../assets/maintenance.jpg';
import gelembungPng from '../assets/icons/gelembung.png';
import galeri1 from '../assets/galeri1.jpg';
import galeri2 from '../assets/galeri2.jpg';
import galeri3 from '../assets/galeri3.jpg';
import galeri4 from '../assets/galeri4.jpg';

const features = [
  {
    title: '100% Higienis & Privat',
    desc: 'Satu mesin hanya untuk satu pelanggan. Kami jamin pakaian Anda tidak akan tercampur dan selalu steril.',
    icon: 'fa-user-shield'
  },
  {
    title: 'Super Cepat, Hanya 2 Jam',
    desc: 'Proses cuci dan kering selesai dalam waktu singkat. Sempurna untuk Anda yang sibuk dan dinamis.',
    icon: 'fa-rocket'
  },
  {
    title: 'Promo & Harga Terbaik',
    desc: 'Nikmati berbagai promo menarik dan harga yang sangat terjangkau untuk semua layanan kami.',
    icon: 'fa-tags'
  }
];

const testimonials = [
  {
    name: 'Andi S.',
    text: 'Tempatnya bersih, mesinnya modern. Nyuci jadi cepet banget, gak sampai 2 jam udah beres. Recommended!',
    stars: 5,
    avatar: 'https://i.pravatar.cc/100?u=andi'
  },
  {
    name: 'Rina W.',
    text: 'Suka banget sama konsep 1 mesin 1 pelanggan, jadi lebih higienis. Harganya juga oke. Bakal langganan di sini.',
    stars: 5,
    avatar: 'https://i.pravatar.cc/100?u=rina'
  },
  {
    name: 'Budi P.',
    text: 'Drop off nya sangat membantu buat yang sibuk. Pakaian jadi wangi dan rapi. Pelayanannya ramah.',
    stars: 5,
    avatar: 'https://i.pravatar.cc/100?u=budi'
  }
];
---

<BaseLayout title="Laundry Ciledug Terpercaya, Cepat & Higienis" description="SR Laundry Express: Jasa laundry modern di Ciledug dengan sistem 1 mesin 1 pelanggan. Layanan cuci kering setrika selesai 2 jam. Tersedia gratis antar jemput!">
  
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(45%_45%_at_50%_50%,rgba(192,0,0,0.05)_0%,rgba(255,255,255,0)_100%)]"></div>
    
    <div class="container mx-auto px-6 relative">
      <!-- Floating Icons -->
      <div class="absolute -top-10 -left-10 md:left-20 animate-bounce delay-700 opacity-20">
        <Image src={gelembungPng} alt="" class="w-16 h-16" />
      </div>

      <div class="max-w-4xl mx-auto text-center">
        <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-50 text-red-700 font-bold text-sm mb-6 border border-red-100">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-600"></span>
          </span>
          Laundry Modern #1 di Ciledug
        </div>
        
        <h1 class="reveal text-5xl md:text-7xl font-black text-gray-900 leading-[1.1] tracking-tight mb-6">
          Pakaian Bersih, <br/>
          <span class="text-red-700">Hidup Lebih Praktis.</span>
        </h1>
        
        <p class="reveal text-lg md:text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed font-medium">
          Selamat datang di SR Laundry Ciledug! Nikmati layanan laundry modern yang cepat, higienis, dan terjangkau. Selesai hanya dalam 2 jam.
        </p>
        
        <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/booking" class="w-full sm:w-auto px-8 py-5 bg-red-700 text-white rounded-2xl font-bold text-lg shadow-xl shadow-red-100 hover:bg-red-800 transition-all transform hover:-translate-y-1 active:scale-95">
            <i class="fab fa-whatsapp mr-2"></i> Booking Sekarang
          </a>
          <a href="/layanan" class="w-full sm:w-auto px-8 py-5 bg-white text-gray-800 border-2 border-gray-100 rounded-2xl font-bold text-lg hover:border-red-100 hover:text-red-700 transition-all">
            Lihat Layanan
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal relative">
          <div class="absolute -inset-4 bg-red-50 rounded-[2rem] -rotate-2 -z-10"></div>
          <Image src={mesinJpg} alt="Mesin Laundry Modern" class="rounded-[1.5rem] shadow-xl w-full object-cover aspect-[4/3]" />
          <div class="absolute bottom-6 -right-6 bg-white p-6 rounded-2xl shadow-xl hidden md:block max-w-[200px] border border-gray-50">
            <p class="text-red-700 font-black text-3xl">2 JAM</p>
            <p class="text-gray-500 font-bold text-sm leading-tight uppercase tracking-wider">Cepat & Tuntas</p>
          </div>
        </div>
        
        <div class="space-y-8">
          <h2 class="reveal text-4xl md:text-5xl font-black text-gray-900 leading-tight">
            Kenapa Kami <span class="text-red-700">Pilihan Terbaik?</span>
          </h2>
          <div class="stagger-reveal space-y-8">
            {features.map(f => (
              <div class="flex items-start gap-6 group">
                <div class="w-14 h-14 shrink-0 flex items-center justify-center rounded-2xl bg-red-50 text-red-700 group-hover:bg-red-700 group-hover:text-white transition-all duration-300">
                  <i class={`fas ${f.icon} text-2xl`}></i>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-900 mb-2">{f.title}</h3>
                  <p class="text-gray-600 leading-relaxed font-medium">{f.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Maintenance Section -->
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 space-y-6">
          <h2 class="reveal text-4xl md:text-5xl font-black text-gray-900 leading-tight uppercase tracking-tighter">
            Mesin Cuci <br/> <span class="text-red-700">Selalu Bersih</span>
          </h2>
          <p class="reveal text-lg text-gray-600 leading-relaxed font-medium">
            Di SR Laundry, kami rutin melakukan pembersihan dan perawatan mesin cuci untuk menjamin kebersihan maksimal setiap cucian pelanggan.
          </p>
          <ul class="stagger-reveal space-y-4">
            {[
              'Sanitasi mesin setiap hari secara intensif',
              'Filter dan tabung dicek berkala oleh teknisi',
              'Menggunakan cairan pembersih ramah lingkungan'
            ].map(item => (
              <li class="flex items-center gap-3 font-bold text-gray-700 uppercase text-xs tracking-widest">
                <div class="w-6 h-6 flex items-center justify-center rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-check text-[10px]"></i>
                </div>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal order-1 lg:order-2">
          <div class="relative">
            <div class="absolute -inset-4 bg-gray-200 rounded-[2rem] rotate-2 -z-10"></div>
            <Image src={maintenanceJpg} alt="Pembersihan Mesin Cuci" class="rounded-[1.5rem] shadow-xl w-full object-cover aspect-[4/3]" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="reveal text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter uppercase">Kualitas Terjamin</h2>
        <p class="text-lg text-gray-600 font-medium">Lihat sendiri bagaimana kami menangani setiap helai pakaian dengan penuh perhatian.</p>
      </div>
      
      <div class="stagger-reveal grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[galeri1, galeri2, galeri3, galeri4].map((img, i) => (
          <div class={`group relative overflow-hidden rounded-3xl shadow-lg aspect-square ${i % 2 === 1 ? 'lg:translate-y-8' : ''}`}>
            <Image src={img} alt="Gallery" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-gray-50 overflow-hidden">
    <div class="container mx-auto px-6">
      <div class="reveal text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tighter uppercase">Apa Kata Mereka?</h2>
        <p class="text-lg text-gray-600 font-medium">Kepuasan Anda adalah kebanggaan kami.</p>
      </div>
      
      <div class="stagger-reveal grid md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl transition-all">
            <div class="flex items-center gap-4 mb-6">
              <img src={t.avatar} alt={t.name} class="w-14 h-14 rounded-full border-2 border-red-50" />
              <div>
                <p class="font-black text-gray-950 uppercase tracking-widest text-xs">{t.name}</p>
                <div class="flex text-amber-400 text-[10px] gap-0.5 mt-1">
                  {[...Array(5)].map(() => <i class="fas fa-star"></i>)}
                </div>
              </div>
            </div>
            <p class="text-gray-600 italic leading-relaxed font-medium">"{t.text}"</p>
          </div>
        ))}
      </div>
      
      <div class="reveal text-center mt-12">
        <a href="/testimoni" class="inline-flex items-center gap-2 font-black text-red-700 uppercase tracking-widest text-xs hover:gap-4 transition-all">
          Lihat Semua Testimoni <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="reveal bg-red-700 rounded-[3rem] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl shadow-red-100">
        <div class="relative z-10">
          <h2 class="text-4xl md:text-6xl font-black mb-6 leading-tight uppercase tracking-tighter">Siap Mencuci?</h2>
          <p class="text-xl text-red-50 mb-10 max-w-2xl mx-auto font-medium opacity-90">
            Rasakan kemudahan dan kebersihan laundry modern di SR Laundry sekarang juga.
          </p>
          <a href="/booking" class="inline-block px-10 py-5 bg-white text-red-700 rounded-2xl font-black text-xl hover:bg-gray-100 transition-all transform hover:-translate-y-1 active:scale-95 shadow-xl">
            BOOKING VIA WHATSAPP
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
