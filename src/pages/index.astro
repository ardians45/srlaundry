---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import mesinJpg from '../assets/mesin.jpg';
import maintenaceJpg from '../assets/maintenace.jpg';
import logoPng from '../assets/logo.png';
import galeri1 from '../assets/galeri1.jpg';
import galeri2 from '../assets/galeri2.jpg';
import galeri3 from '../assets/galeri3.jpg';
import galeri4 from '../assets/galeri4.jpg';

const features = [
  {
    title: '100% Higienis',
    desc: 'Satu mesin satu pelanggan. Higienitas mutlak tanpa kompromi.',
    icon: 'fa-shield-heart'
  },
  {
    title: 'Express 2 Jam',
    desc: 'Teknologi modern untuk hasil kilat yang tetap sempurna.',
    icon: 'fa-bolt-lightning'
  },
  {
    title: 'Self Service',
    desc: 'Kontrol penuh di tangan Anda dengan sistem coin praktis.',
    icon: 'fa-hands-bubbles'
  }
];

const testimonials = [
  { name: 'Andi S.', text: 'Nyuci jadi cepet banget, gak sampai 2 jam udah beres. Recommended!', avatar: 'https://i.pravatar.cc/100?u=andi' },
  { name: 'Rina W.', text: 'Satu mesin satu pelanggan, jadi lebih higienis. Bakal langganan terus!', avatar: 'https://i.pravatar.cc/100?u=rina' },
  { name: 'Budi P.', text: 'Drop off nya sangat membantu buat yang sibuk. Pakaian jadi wangi dan rapi.', avatar: 'https://i.pravatar.cc/100?u=budi' }
];
---

<BaseLayout title="Laundry Ciledug Terpercaya, Cepat & Higienis">
  
  <!-- HERO SECTION: Cinematic & Minimalist -->
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-white">
    <div class="absolute inset-0 z-0 opacity-40">
      <div class="absolute top-[-10%] right-[-10%] w-[500px] h-[500px] bg-red-100 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-red-50 rounded-full blur-[120px]"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-5xl">
        <div class="reveal inline-flex items-center gap-3 px-4 py-2 bg-red-50 text-red-700 rounded-full font-bold text-xs uppercase tracking-[0.2em] mb-8">
          <span class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></span>
          Standard Laundry Masa Depan
        </div>
        
        <h1 class="reveal text-[clamp(2.5rem,8vw,6rem)] font-black text-gray-950 leading-[0.9] tracking-[-0.04em] mb-10">
          BERSIH. <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-600 to-red-800 italic">HIGIENIS.</span> <br/>
          KILAT.
        </h1>

        <div class="reveal flex flex-col md:flex-row items-start md:items-center gap-8 mb-16">
          <p class="text-xl text-gray-600 max-w-md leading-relaxed">
            Menghadirkan teknologi laundry modern dengan sistem 1 Mesin 1 Pelanggan. Higienitas Anda adalah prioritas mutlak kami.
          </p>
          <div class="h-1 w-20 bg-gray-200 hidden md:block"></div>
          <div class="flex flex-col">
            <span class="font-black text-4xl text-gray-950 leading-none">2 JAM</span>
            <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Selesai Tuntas</span>
          </div>
        </div>

        <div class="reveal flex flex-wrap gap-4">
          <a href="/booking" class="group relative px-10 py-5 bg-red-700 text-white rounded-full font-black text-lg overflow-hidden transition-all hover:pr-14">
            <span class="relative z-10">BOOKING SEKARANG</span>
            <i class="fas fa-arrow-right absolute right-6 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all"></i>
          </a>
          <a href="/layanan" class="px-10 py-5 bg-white border border-gray-200 text-gray-950 rounded-full font-black text-lg hover:bg-gray-50 transition-all">
            LIHAT HARGA
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES: Bento Grid Style -->
  <section class="py-32 bg-[#fafafa]">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-6">
        
        <!-- Large Card -->
        <div class="reveal lg:col-span-8 bg-white rounded-[3rem] p-12 shadow-sm border border-gray-100 flex flex-col md:flex-row gap-12 items-center">
          <div class="md:w-1/2">
            <h2 class="text-4xl font-black text-gray-950 leading-tight mb-6">Standard Baru <br/> Kebersihan Pakaian.</h2>
            <p class="text-gray-600 font-medium mb-8">Kami melakukan perawatan dan sanitasi mesin secara berkala untuk menjamin setiap helai pakaian Anda steril.</p>
            <div class="space-y-4">
              {['Sanitasi harian', 'Filter berkala', 'Eco-friendly chemical'].map(item => (
                <div class="flex items-center gap-3 font-bold text-gray-950 uppercase text-xs tracking-widest">
                  <i class="fas fa-check text-red-600"></i> {item}
                </div>
              ))}
            </div>
          </div>
          <div class="md:w-1/2 rounded-[2rem] overflow-hidden rotate-2">
            <Image src={mesinJpg} alt="Mesin" class="w-full h-full object-cover aspect-square" />
          </div>
        </div>

        <!-- Small Card -->
        <div class="reveal lg:col-span-4 bg-red-700 rounded-[3rem] p-12 text-white flex flex-col justify-between overflow-hidden relative group">
          <i class="fas fa-rocket absolute -right-10 -bottom-10 text-[15rem] opacity-10 group-hover:scale-110 transition-transform"></i>
          <div>
            <span class="inline-block px-3 py-1 bg-white/20 rounded-full font-bold text-[10px] tracking-[0.2em] uppercase mb-4">Layanan Unggulan</span>
            <h3 class="text-3xl font-black leading-tight">Drop-Off <br/> Express.</h3>
          </div>
          <p class="relative z-10 font-medium opacity-80">Sibuk? Titipkan pakaian kotor Anda, tim kami akan mengurus segalanya hingga tuntas dan rapi.</p>
          <a href="/layanan" class="mt-6 font-black uppercase text-xs tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all">
            Selengkapnya <i class="fas fa-arrow-right"></i>
          </a>
        </div>

        {/* Icons Grid */}
        <div class="stagger-reveal lg:col-span-12 grid md:grid-cols-3 gap-6">
          {features.map(f => (
            <div class="bg-white p-10 rounded-[2.5rem] border border-gray-100 hover:shadow-xl transition-all group">
              <div class="w-16 h-16 bg-red-50 text-red-700 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-red-700 group-hover:text-white transition-all">
                <i class={`fas ${f.icon} text-2xl`}></i>
              </div>
              <h4 class="text-xl font-black text-gray-950 mb-3 uppercase tracking-tighter">{f.title}</h4>
              <p class="text-gray-500 font-medium leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY: Modern Masonry feel -->
  <section class="py-32 bg-white overflow-hidden">
    <div class="container mx-auto px-6">
      <div class="reveal flex flex-col md:flex-row justify-between items-end gap-8 mb-20">
        <div>
          <h2 class="text-5xl font-black text-gray-950 tracking-tighter mb-4 uppercase">Seni <br/> Mengurus Pakaian.</h2>
          <p class="text-gray-500 font-medium max-w-sm">Setiap lipatan dan aroma harum adalah dedikasi kami untuk kenyamanan hidup Anda.</p>
        </div>
        <a href="/layanan" class="font-black text-red-700 uppercase tracking-widest text-xs flex items-center gap-3 group">
          Lihat Galeri Lengkap <div class="w-12 h-12 rounded-full border border-gray-100 flex items-center justify-center group-hover:bg-red-700 group-hover:text-white transition-all"><i class="fas fa-arrow-right"></i></div>
        </a>
      </div>

      <div class="stagger-reveal grid grid-cols-2 lg:grid-cols-4 gap-4">
        {[galeri1, galeri2, galeri3, galeri4].map((img, i) => (
          <div class={`relative rounded-[2rem] overflow-hidden aspect-[3/4] ${i % 2 === 1 ? 'lg:translate-y-12' : ''}`}>
            <Image src={img} alt="Laundry" class="w-full h-full object-cover transition-transform duration-1000 hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 hover:opacity-100 transition-opacity"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS: Clean & Elegant -->
  <section class="py-32 bg-[#fafafa]">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-3 gap-12">
        {testimonials.map(t => (
          <div class="reveal bg-white p-12 rounded-[3rem] border border-gray-100 flex flex-col justify-between">
            <p class="text-2xl font-bold text-gray-950 leading-relaxed mb-12 italic">"{t.text}"</p>
            <div class="flex items-center gap-4">
              <img src={t.avatar} alt={t.name} class="w-14 h-14 rounded-full" />
              <div>
                <span class="block font-black text-gray-950 uppercase tracking-widest text-xs">{t.name}</span>
                <span class="text-red-700 text-[10px] flex gap-1">
                  {[...Array(5)].map(() => <i class="fas fa-star"></i>)}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA: The Final Blow -->
  <section class="py-32">
    <div class="container mx-auto px-6">
      <div class="reveal relative bg-gray-950 rounded-[4rem] p-16 md:p-32 text-center overflow-hidden">
        <div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
        <div class="relative z-10">
          <h2 class="text-4xl md:text-7xl font-black text-white leading-none mb-10 tracking-tighter uppercase">
            Pakaian Anda <br/> Berhak Mendapat <br/> <span class="text-red-600">Terbaik.</span>
          </h2>
          <div class="flex flex-col md:flex-row justify-center gap-6">
            <a href="/booking" class="bg-red-700 text-white px-12 py-6 rounded-full font-black text-xl hover:bg-red-800 transition-all shadow-2xl shadow-red-950/40 transform hover:-translate-y-1 active:scale-95">
              BOOKING WHATSAPP
            </a>
            <a href="/kontak" class="bg-white/10 text-white px-12 py-6 rounded-full font-black text-xl hover:bg-white/20 transition-all backdrop-blur-md">
              KUNJUNGI CABANG
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
