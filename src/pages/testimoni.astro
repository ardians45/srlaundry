---
import BaseLayout from '../layouts/BaseLayout.astro';

const testimonials = [
  { name: 'Akbar Dj', text: 'Servicenya profesional, rapi, ramah, bersih, cepat, dan tepat waktu. Fasilitas sangat mendukung.', stars: 5, avatar: 'AkbarDj' },
  { name: 'Selfya Rohannia', text: 'Semua karyawan ramah, baik, sopan. Pelayanan sangat memuaskan, bersih, wangi, rapi.', stars: 5, avatar: 'SelfyaRohannia' },
  { name: 'The Cida Rana Channel', text: 'Baru pertama nyuci langsung jadi langganan. Pelayanan ramah. 7kg hanya 20 ribu. Membantu saat musim susah air.', stars: 5, avatar: 'CidaRana' },
  { name: 'Na Nunung', text: 'Sangat rapi dan wangi, lokasi terjangkau, staf ramah, tempat nyaman dan bersih.', stars: 5, avatar: 'NaNunung' },
  { name: 'Femy Roza', text: 'Pelayanan cepat, pakaian rapi dan wangi. Bisa cuci kering saja. Cocok buat yang sibuk.', stars: 5, avatar: 'FemyRoza' },
  { name: 'Ibuk Hana', text: 'Pelayanan ramah, hasil bersih, wangi, dan rapi. Hemat waktu dan tenaga.', stars: 5, avatar: 'IbukHana' },
  { name: 'Ardian Setiawan', text: 'Cepat dan rapi, pelayanannya ramah 👍', stars: 5, avatar: 'ArdianSetiawan' },
  { name: 'Gatot Saputra', text: 'Fasilitas oke, harga terjangkau, dijamin bersih, wangi, rapi.', stars: 5, avatar: 'GatotSaputra' },
  { name: 'Nurlastri Lastri', text: 'Langganan 4 bulan, pelayanan bagus, harga terjangkau, cocok untuk cuci express.', stars: 5, avatar: 'Nurlastri' },
  { name: 'Almi Susanti', text: 'Proses cepat, rapi, pelayanan ramah, dan wangi. Tidak mengecewakan.', stars: 5, avatar: 'AlmiSusanti' },
  { name: 'Mohammad Anwar', text: 'Proses cepat, hasil wangi dan rapi.', stars: 5, avatar: 'MohammadAnwar' },
  { name: 'Sri Maryati', text: 'Dijamin nagihhh 😍', stars: 5, avatar: 'SriMaryati' }
];
---

<BaseLayout title="Ulasan Pelanggan SR Laundry Express Ciledug" description="Apa kata mereka tentang SR Laundry? Baca testimoni jujur dari ribuan pelanggan puas kami di Ciledug mengenai kecepatan dan kebersihan layanan kami.">
  
  <section class="pt-32 pb-20 bg-red-50">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-6xl font-black text-gray-900 mb-6">Suara Pelanggan</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">Kami bangga telah menerima 30+ ulasan positif. Inilah sebagian kecil dari apa yang mereka katakan tentang kami.</p>
      
      <div class="mt-8 flex justify-center gap-4">
        <a href="https://maps.app.goo.gl/neGZtRQdgWPNuQbPA" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-bold text-red-700 hover:underline">
          <i class="fab fa-google"></i> Lihat di Google Maps
        </a>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container mx-auto px-6">
      <div class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
        {testimonials.map(t => (
          <div class="break-inside-avoid bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center text-white font-black text-sm uppercase">
                {t.name.split(' ').map(n => n[0]).join('').substring(0, 2)}
              </div>
              <div>
                <p class="font-black text-gray-950 leading-tight">{t.name}</p>
                <div class="flex text-amber-400 text-[10px] mt-1">
                  {[...Array(t.stars)].map(() => <i class="fas fa-star"></i>)}
                </div>
              </div>
            </div>
            <p class="text-gray-600 leading-relaxed font-medium italic">"{t.text}"</p>
            <div class="mt-6 flex justify-end">
              <i class="fas fa-quote-right text-3xl text-red-50"></i>
            </div>
          </div>
        ))}
      </div>
      
      <div class="mt-20 p-12 rounded-[3rem] bg-gray-900 text-white text-center">
        <h3 class="text-3xl font-black mb-4">Punya Pengalaman Menarik?</h3>
        <p class="text-gray-400 mb-8 max-w-xl mx-auto font-medium">
          Bagikan pengalaman Anda menggunakan jasa kami dan bantu orang lain menemukan layanan laundry terbaik di Ciledug.
        </p>
        <a href="https://g.page/r/CU7_Fh5ptIOTEB0/review" target="_blank" rel="noopener noreferrer" class="inline-block bg-red-700 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-red-800 transition-all shadow-xl shadow-red-900/20">
          Tulis Ulasan Anda
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
