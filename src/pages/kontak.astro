---
import BaseLayout from '../layouts/BaseLayout.astro';

const branches = [
  { name: 'Larangan', address: 'RT.002/RW.013, Larangan Selatan, Kec. Larangan, Kota Tangerang, Banten 15154', maps: 'https://maps.app.goo.gl/neGZtRQdgWPNuQbPA' },
  { name: 'Paninggilan', address: 'Jl. Paninggilan Raya, Ciledug', status: 'Aktif' },
  { name: 'Parung Serab', address: 'Jl. Parung Serab, Ciledug', status: 'Aktif' },
  { name: 'Sukarela', address: 'Jl. Sukarela, Ciledug', status: 'Segera Hadir' }
];
---

<BaseLayout title="Kontak & Lokasi Cabang SR Laundry di Ciledug" description="Hubungi SR Laundry Express via WhatsApp untuk layanan antar jemput laundry. Kunjungi cabang kami di Larangan, Paninggilan, dan Parung Serab untuk hasil terbaik.">
  
  <section class="pt-32 pb-20 bg-red-50">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-6xl font-black text-gray-900 mb-6">Hubungi Kami</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">Punya pertanyaan atau ingin mampir? Kami selalu siap menyambut Anda di cabang terdekat.</p>
    </div>
  </section>

  <section class="py-24">
    <div class="container mx-auto px-6">
      
      <div class="grid lg:grid-cols-3 gap-12">
        
        <!-- Info Cards -->
        <div class="lg:col-span-1 space-y-8">
          <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-gray-100">
            <h2 class="text-2xl font-black mb-8 flex items-center gap-3">
              <i class="fas fa-phone-alt text-red-700"></i> Kontak Langsung
            </h2>
            <div class="space-y-4">
              <a href="https://wa.me/6281297252322" class="flex items-center justify-center gap-3 w-full py-4 bg-green-500 text-white rounded-2xl font-bold text-lg hover:bg-green-600 transition-all shadow-lg shadow-green-100">
                <i class="fab fa-whatsapp"></i> WhatsApp Admin
              </a>
              <a href="https://www.instagram.com/srlaundrycoin/" class="flex items-center justify-center gap-3 w-full py-4 bg-gradient-to-r from-purple-600 to-pink-500 text-white rounded-2xl font-bold text-lg hover:opacity-90 transition-all shadow-lg shadow-pink-100">
                <i class="fab fa-instagram"></i> Instagram
              </a>
            </div>
          </div>

          <div class="bg-red-700 p-10 rounded-[2.5rem] text-white shadow-xl shadow-red-100">
            <i class="fas fa-clock text-4xl mb-6 text-red-200"></i>
            <h2 class="text-2xl font-black mb-2">Jam Operasional</h2>
            <p class="text-4xl font-black mb-2">07:00 - 21:00</p>
            <p class="text-red-100 font-bold uppercase tracking-widest text-sm">Buka Setiap Hari</p>
          </div>
        </div>

        <!-- Branches -->
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-gray-100">
            <h2 class="text-2xl font-black mb-8 flex items-center gap-3">
              <i class="fas fa-store text-red-700"></i> Cabang Kami
            </h2>
            <div class="grid md:grid-cols-2 gap-6">
              {branches.map(b => (
                <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 group hover:border-red-200 hover:bg-white transition-all">
                  <div class="flex justify-between items-start mb-4">
                    <h3 class="font-black text-gray-900 text-lg">Cabang {b.name}</h3>
                    {b.status === 'Segera Hadir' ? (
                      <span class="bg-amber-100 text-amber-700 text-[10px] font-black px-2 py-1 rounded-md uppercase">Soon</span>
                    ) : (
                      <span class="bg-green-100 text-green-700 text-[10px] font-black px-2 py-1 rounded-md uppercase">Active</span>
                    )}
                  </div>
                  <p class="text-gray-500 text-sm mb-4 leading-relaxed font-medium">{b.address}</p>
                  {b.maps && (
                    <a href={b.maps} target="_blank" class="text-red-700 font-bold text-sm hover:underline flex items-center gap-2">
                      Buka di Google Maps <i class="fas fa-external-link-alt text-[10px]"></i>
                    </a>
                  )}
                </div>
              ))}
            </div>
          </div>

          <!-- Map iframe -->
          <div class="rounded-[2.5rem] overflow-hidden shadow-sm border border-gray-100 h-[400px]">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.191244439065!2d106.71375!3d-6.2385!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69fa8943343881%3A0x8e83b4691e147ed4!2sSR%20Laundry%20Coin!5e0!3m2!1sen!2sid!4v1688888888888" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
