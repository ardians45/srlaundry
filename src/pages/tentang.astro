---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import interiorJpg from '../assets/interior.jpg';
import team1 from '../assets/team1.jpg';
import team2 from '../assets/team2.jpg';
import team3 from '../assets/team3.jpg';
import team4 from '../assets/team4.jpg';
import team5 from '../assets/team5.jpg';

const values = [
  {
    title: 'Kepuasan Pelanggan',
    desc: 'Kami mendengarkan dan terus memperbaiki layanan demi kenyamanan Anda.',
    icon: 'fa-heart'
  },
  {
    title: 'Inovasi Layanan',
    desc: 'Booking via WhatsApp, promo digital, dan sistem self-service yang praktis.',
    icon: 'fa-lightbulb'
  },
  {
    title: 'Kebersihan Total',
    desc: 'Mesin disanitasi setiap hari dan area kami jaga selalu steril.',
    icon: 'fa-sparkles'
  }
];
---

<BaseLayout title="Profil SR Laundry - Jasa Cuci Profesional di Ciledug" description="Mengenal SR Laundry Express, pelopor laundry modern dengan teknologi coin di Ciledug. Komitmen kami memberikan hasil cucian paling bersih, wangi, dan rapi.">
  
  <section class="pt-32 pb-20 bg-red-50 relative overflow-hidden">
    <div class="container mx-auto px-6 text-center relative z-10">
      <h1 class="text-4xl md:text-6xl font-black text-gray-900 mb-6">Tentang SR Laundry</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto italic leading-relaxed">
        “Di SR Laundry, kami percaya bahwa mencuci pakaian tak harus ribet. Cukup datang, cuci, dan beres dalam 2 jam!”
      </p>
    </div>
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-red-100 rounded-full blur-3xl opacity-50 -mr-32 -mt-32"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-red-100 rounded-full blur-3xl opacity-50 -ml-32 -mb-32"></div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="absolute -inset-4 bg-red-700 rounded-3xl rotate-3"></div>
          <Image src={interiorJpg} alt="Interior SR Laundry" class="relative rounded-2xl shadow-2xl w-full h-full object-cover aspect-video lg:aspect-square" />
        </div>
        
        <div class="space-y-8">
          <h2 class="text-4xl font-black text-gray-950 leading-tight">
            Selamat Datang di <span class="text-red-700">SR Laundry</span>
          </h2>
          <p class="text-lg text-gray-600 leading-relaxed">
            SR Laundry adalah layanan laundry modern berbasis teknologi yang hadir di wilayah Ciledug. Kami berkomitmen memberikan pengalaman mencuci terbaik melalui dua pilihan layanan utama: 
            <span class="font-bold text-gray-900">Self-Service</span> dan <span class="font-bold text-gray-900">Drop-Off</span>.
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-3">
              <i class="fas fa-microchip text-2xl text-red-700"></i>
              <h3 class="font-bold text-gray-900 uppercase tracking-wider text-xs">Teknologi Coin</h3>
              <p class="text-sm text-gray-500">Sistem pembayaran praktis menggunakan koin untuk layanan Self-Service.</p>
            </div>
            <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-3">
              <i class="fas fa-shield-virus text-2xl text-red-700"></i>
              <h3 class="font-bold text-gray-900 uppercase tracking-wider text-xs">1 Mesin 1 Pelanggan</h3>
              <p class="text-sm text-gray-500">Menjamin kebersihan dan privasi pakaian Anda tetap terjaga.</p>
            </div>
          </div>
          <p class="text-lg text-gray-600 leading-relaxed">
            Proses cepat, tempat nyaman, dan hasil maksimal adalah alasan pelanggan setia terus kembali kepada kami. Kami tidak hanya mencuci pakaian, kami mencuci dengan peduli.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-gray-950 text-white overflow-hidden">
    <div class="container mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="text-4xl md:text-5xl font-black mb-6">Dijalankan oleh Tim Profesional</h2>
        <p class="text-lg text-gray-400">
          Kami tidak hanya mengandalkan mesin modern, tetapi juga tim yang ramah, terlatih, dan berdedikasi untuk memberikan pelayanan terbaik bagi Anda.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="col-span-2 row-span-2 overflow-hidden rounded-3xl group">
          <Image src={team1} alt="Team SR Laundry" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        </div>
        <div class="overflow-hidden rounded-3xl group aspect-square">
          <Image src={team2} alt="Team member" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </div>
        <div class="overflow-hidden rounded-3xl group aspect-square">
          <Image src={team3} alt="Team member" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </div>
        <div class="overflow-hidden rounded-3xl group aspect-square">
          <Image src={team4} alt="Team member" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </div>
        <div class="overflow-hidden rounded-3xl group aspect-square">
          <Image src={team5} alt="Team member" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </div>
      </div>
      
      <div class="mt-20 text-center">
        <blockquote class="text-2xl md:text-3xl font-black italic max-w-4xl mx-auto text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-amber-400">
          “Visi kami adalah menjadi mitra terpercaya untuk kebutuhan harian Anda dengan menyediakan layanan laundry paling higienis dan efisien.”
        </blockquote>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-12">
        {values.map(v => (
          <div class="group p-10 rounded-[2.5rem] bg-gray-50 border border-gray-100 hover:bg-white hover:shadow-2xl hover:shadow-red-100 transition-all duration-300 transform hover:-translate-y-2 text-center">
            <div class="w-20 h-20 mx-auto flex items-center justify-center rounded-3xl bg-red-700 text-white mb-8 shadow-lg shadow-red-100 group-hover:rotate-12 transition-transform">
              <i class={`fas ${v.icon} text-3xl`}></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 mb-4">{v.title}</h3>
            <p class="text-gray-600 leading-relaxed font-medium">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
